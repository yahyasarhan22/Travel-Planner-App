<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_medium"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/admin_item_destination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destination"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admin_item_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="@color/left_primary"
            android:textSize="14sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_item_edit"
        android:layout_width="75dp"
        android:layout_height="40dp"
        android:backgroundTint="@color/left_accent"
        android:text="Edit"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:layout_marginEnd="4dp" />

    <Button
        android:id="@+id/btn_item_delete"
        android:layout_width="75dp"
        android:layout_height="40dp"
        android:backgroundTint="#EB5757"
        android:text="Delete"
        android:textColor="@color/white"
        android:textSize="12sp" />

</LinearLayout>