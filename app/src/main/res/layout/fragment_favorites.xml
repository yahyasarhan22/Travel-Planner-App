<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/left_bg_light"
    android:padding="@dimen/spacing_medium">

    <!-- Screen title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My Favorites"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/left_primary_dark"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <!-- Shown when no favorites exist -->
    <TextView
        android:id="@+id/textView_noFavorites"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You have no favorite trips yet."
        android:textSize="15sp"
        android:textColor="@color/gray_text"
        android:gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone" />

    <!-- List of favorite trips -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView_favorites"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_medium" />

</LinearLayout>