<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/left_bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large"
        android:gravity="center_horizontal">

        <!-- Screen title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/left_primary_dark"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Profile picture circle -->
        <ImageView
            android:id="@+id/imageView_profilePic"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@color/left_primary"
            android:scaleType="centerCrop"
            android:contentDescription="Profile Picture"
            android:layout_marginBottom="@dimen/spacing_small" />

        <!-- Button to pick a new profile picture -->
        <Button
            android:id="@+id/button_changePic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Photo"
            android:textColor="@color/left_primary"
            android:background="@android:color/transparent"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- First Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="First Name"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_profile_firstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="First name"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Last Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last Name"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_profile_lastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Last name"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Phone -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_profile_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phone number"
            android:inputType="phone"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- New Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="New Password (leave blank to keep current)"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_profile_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter new password"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Confirm New Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm New Password"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_profile_confirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm new password"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Save button -->
        <Button
            android:id="@+id/button_saveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Changes"
            android:textColor="@color/white"
            android:backgroundTint="@color/left_primary"
            android:padding="@dimen/spacing_medium" />

    </LinearLayout>

</ScrollView>