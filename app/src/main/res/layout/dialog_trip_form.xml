<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/spacing_large">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/dialog_form_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trip Details Form"
            android:textColor="@color/left_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <EditText
            android:id="@+id/dialog_et_destination"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:hint="Destination Name"
            android:inputType="text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/dialog_et_country"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:hint="Country"
            android:inputType="text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/dialog_et_duration"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:hint="Duration (Days)"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/dialog_et_price"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:hint="Price ($)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/dialog_et_description"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Description Overview"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/dialog_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:text="Cancel"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/dialog_btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/left_primary"
                android:text="Save"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>