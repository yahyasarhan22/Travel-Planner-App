<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/left_bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large"
        android:gravity="center_horizontal">

        <!-- Screen title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/left_primary_dark"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="@dimen/spacing_small" />

        <!-- Small subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fill in your details to get started"
            android:textSize="13sp"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_reg_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- First Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="First Name"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_firstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your first name"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Last Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last Name"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_lastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your last name"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_reg_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="At least 6 chars, 1 letter, 1 number"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Confirm Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_confirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Re-enter your password"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Gender Spinner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_gender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Major Spinner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Major"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_major"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Phone Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="@color/left_primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editText_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your phone number"
            android:inputType="phone"
            android:background="@drawable/input_background"
            android:padding="@dimen/spacing_medium"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_text"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- Register button -->
        <Button
            android:id="@+id/button_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="@color/white"
            android:backgroundTint="@color/left_primary"
            android:padding="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Back to login -->
        <Button
            android:id="@+id/button_backToLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Already have an account? Login"
            android:textColor="@color/left_primary"
            android:background="@android:color/transparent"
            android:padding="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_large" />

    </LinearLayout>

</ScrollView>