<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/left_bg_light"
    android:padding="@dimen/spacing_large">

    <!-- Dialog title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book This Trip"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/left_primary_dark"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <!-- Trip name display (read only) -->
    <TextView
        android:id="@+id/textView_dialog_tripName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trip: --"
        android:textSize="14sp"
        android:textColor="@color/gray_text"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <!-- Quantity label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Number of Seats"
        android:textColor="@color/left_primary_dark"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <!-- Quantity input -->
    <EditText
        android:id="@+id/editText_quantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter number of seats"
        android:inputType="number"
        android:background="@drawable/input_background"
        android:padding="@dimen/spacing_medium"
        android:textColor="@color/black"
        android:textColorHint="@color/gray_text"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <!-- Reservation type label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reservation Type"
        android:textColor="@color/left_primary_dark"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <!-- Reservation type spinner -->
    <Spinner
        android:id="@+id/spinner_reservationType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background"
        android:padding="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_large" />

    <!-- Confirm button -->
    <Button
        android:id="@+id/button_confirmReservation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Reservation"
        android:textColor="@color/white"
        android:backgroundTint="@color/left_primary"
        android:padding="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_small" />

    <!-- Cancel button -->
    <Button
        android:id="@+id/button_cancelReservation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:textColor="@color/left_primary"
        android:background="@android:color/transparent"
        android:padding="@dimen/spacing_medium" />

</LinearLayout>